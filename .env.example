# ─── DATABASE (Neon PostgreSQL) ───────────────────────────────────────────────
# Obtén esta URL en https://console.neon.tech → Tu proyecto → Connection string
DATABASE_URL="postgresql://usuario:password@ep-xxxxx.us-east-2.aws.neon.tech/valotourneys?sslmode=require"

# ─── CLERK AUTH ───────────────────────────────────────────────────────────────
# Obtén estas keys en https://dashboard.clerk.com → Tu app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
CLERK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# URLs de redirección de Clerk (no cambiar)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ─── HENRIK DEV API (Riot data) ───────────────────────────────────────────────
# Obtén tu key en https://docs.henrikdev.xyz/
HENRIK_API_KEY="HDEV-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# ─── GROQ (IA Alioth) ─────────────────────────────────────────────────────────
# Obtén tu key en https://console.groq.com/keys
GROQ_API_KEY="gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ─── CLOUDINARY (fotos de jugadores y equipos) ────────────────────────────────
# Obtén estas keys en https://console.cloudinary.com/
CLOUDINARY_CLOUD_NAME="tu_cloud_name"
CLOUDINARY_API_KEY="xxxxxxxxxxxxxxx"
CLOUDINARY_API_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="tu_cloud_name"

# ─── APP ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── ADMIN ────────────────────────────────────────────────────────────────────
# Email del administrador principal (se le asigna rol ADMIN automáticamente)
ADMIN_EMAIL="tu_email@gmail.com"
