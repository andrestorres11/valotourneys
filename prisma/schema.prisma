generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PLAYER
  ADMIN
}

enum Rank {
  IRON_1
  IRON_2
  IRON_3
  BRONZE_1
  BRONZE_2
  BRONZE_3
  SILVER_1
  SILVER_2
  SILVER_3
  GOLD_1
  GOLD_2
  GOLD_3
  PLATINUM_1
  PLATINUM_2
  PLATINUM_3
  DIAMOND_1
  DIAMOND_2
  DIAMOND_3
  ASCENDANT_1
  ASCENDANT_2
  ASCENDANT_3
  IMMORTAL_1
  IMMORTAL_2
  IMMORTAL_3
  RADIANT
  UNRANKED
}

enum GameMode {
  COMPETITIVE
  UNRATED
  SPIKE_RUSH
  DEATHMATCH
  ESCALATION
  REPLICATION
}

enum TournamentStatus {
  DRAFT
  REGISTRATION_OPEN
  REGISTRATION_CLOSED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PhaseType {
  GROUP_STAGE
  ROUND_OF_16
  QUARTERFINALS
  SEMIFINALS
  FINALS
  GRAND_FINALS
}

enum MatchStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  FORFEIT
}

enum TeamStatus {
  ACTIVE
  DISBANDED
  SUSPENDED
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
}

enum PrizeType {
  CASH
  TRANSFER
  GIFT_CARD
  PRODUCT
  OTHER
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  username  String   @unique
  role      Role     @default(PLAYER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  player Player?

  @@index([clerkId])
  @@index([email])
}

model Player {
  id            String    @id @default(cuid())
  userId        String    @unique
  riotId        String?   @unique
  gameName      String?
  tagLine       String?
  currentRank   Rank      @default(UNRANKED)
  peakRank      Rank      @default(UNRANKED)
  photoUrl      String?
  bio           String?
  country       String?
  kills         Int       @default(0)
  deaths        Int       @default(0)
  assists       Int       @default(0)
  wins          Int       @default(0)
  losses        Int       @default(0)
  headshotPct   Float     @default(0)
  favoriteAgent String?
  lastSyncAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamMembers     TeamMember[]
  sentInvites     TeamInvite[]   @relation("InviteSender")
  receivedInvites TeamInvite[]   @relation("InviteReceiver")
  freeAgentProfile FreeAgent?

  @@index([riotId])
  @@index([currentRank])
}

model Team {
  id          String     @id @default(cuid())
  name        String     @unique
  tag         String     @db.VarChar(5)
  logoUrl     String?
  description String?
  status      TeamStatus @default(ACTIVE)
  captainId   String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  members       TeamMember[]
  invites       TeamInvite[]
  registrations TournamentRegistration[]

  @@index([captainId])
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  playerId  String
  isCapitan Boolean  @default(false)
  joinedAt  DateTime @default(now())

  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([teamId, playerId])
  @@index([teamId])
  @@index([playerId])
}

model TeamInvite {
  id         String       @id @default(cuid())
  teamId     String
  senderId   String
  receiverId String
  status     InviteStatus @default(PENDING)
  message    String?
  expiresAt  DateTime
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  team     Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  sender   Player @relation("InviteSender", fields: [senderId], references: [id])
  receiver Player @relation("InviteReceiver", fields: [receiverId], references: [id])

  @@index([receiverId, status])
}

model FreeAgent {
  id        String   @id @default(cuid())
  playerId  String   @unique
  roles     String[]
  message   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

model Tournament {
  id                String           @id @default(cuid())
  name              String
  description       String?
  logoUrl           String?
  bannerUrl         String?
  gameMode          GameMode
  status            TournamentStatus @default(DRAFT)
  minRank           Rank             @default(UNRANKED)
  maxRank           Rank             @default(RADIANT)
  maxTeams          Int              @default(16)
  teamSize          Int              @default(5)
  registrationStart DateTime?
  registrationEnd   DateTime?
  startDate         DateTime?
  endDate           DateTime?

  // Inscripcion con pago
  hasPaidEntry      Boolean          @default(false)
  entryFee          Float?
  entryCurrency     String?          @default("COP")
  paymentInstructions String?        // nequi, bancolombia, etc.
  paymentRecipient  String?          // numero o cuenta destino

  rules             String?
  createdById       String
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  registrations TournamentRegistration[]
  phases        Phase[]
  prizes        TournamentPrize[]

  @@index([status])
  @@index([createdById])
}

model TournamentPrize {
  id           String    @id @default(cuid())
  tournamentId String
  position     Int       // 1 = 1er lugar, 2 = 2do, etc.
  label        String    // "Campeón", "Subcampeón", etc.
  prizeType    PrizeType @default(CASH)
  amount       Float?    // si es dinero
  currency     String?   @default("COP")
  description  String?   // descripcion libre del premio
  winnerId     String?   // teamId que ganó este premio
  paidAt       DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([tournamentId])
  @@unique([tournamentId, position])
}

model TournamentRegistration {
  id              String        @id @default(cuid())
  tournamentId    String
  teamId          String
  checkedIn       Boolean       @default(false)
  seed            Int?

  // Pago
  paymentStatus   PaymentStatus @default(PENDING)
  paymentProofUrl String?       // URL cloudinary del comprobante
  paymentProofId  String?       // public_id cloudinary para borrar
  paymentNote     String?       // nota del jugador al subir
  reviewedAt      DateTime?     // cuando admin revisó
  reviewedBy      String?       // userId del admin que revisó
  rejectionReason String?       // motivo de rechazo

  registeredAt DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team       Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, teamId])
  @@index([tournamentId])
  @@index([paymentStatus])
}

model Phase {
  id           String    @id @default(cuid())
  tournamentId String
  type         PhaseType
  name         String
  order        Int
  isCompleted  Boolean   @default(false)
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  groups     Group[]
  matches    Match[]

  @@index([tournamentId, order])
}

model Group {
  id      String @id @default(cuid())
  phaseId String
  name    String
  order   Int

  phase     Phase          @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  matches   Match[]
  standings GroupStanding[]

  @@index([phaseId])
}

model GroupStanding {
  id         String @id @default(cuid())
  groupId    String
  teamId     String
  played     Int    @default(0)
  wins       Int    @default(0)
  losses     Int    @default(0)
  roundsWon  Int    @default(0)
  roundsLost Int    @default(0)
  points     Int    @default(0)

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, teamId])
  @@index([groupId])
}

model Match {
  id              String      @id @default(cuid())
  phaseId         String
  groupId         String?
  team1Id         String?
  team2Id         String?
  winnerId        String?
  team1Score      Int         @default(0)
  team2Score      Int         @default(0)
  status          MatchStatus @default(SCHEDULED)
  scheduledAt     DateTime?
  playedAt        DateTime?
  bracketRound    Int?
  bracketPosition Int?
  nextMatchId     String?
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  phase Phase  @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  group Group? @relation(fields: [groupId], references: [id])

  @@index([phaseId])
  @@index([groupId])
  @@index([status])
}
